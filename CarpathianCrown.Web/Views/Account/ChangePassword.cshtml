@model CarpathianCrown.Web.Models.ChangePasswordVm

@{
    var lang = Context.GetLang();
    string T(string ua, string en) => lang == "en" ? en : ua;
}

<h1>@T("Зміна пароля", "Change password")</h1>

@if (ViewBag.Error != null)
{
<div class="alert">@ViewBag.Error</div>
}

<form method="post" class="card" style="padding:24px;">
    <label>@T("Поточний пароль", "Current password")</label>
    <input asp-for="CurrentPassword" type="password" />

    <label>@T("Новий пароль", "New password")</label>
    <input asp-for="NewPassword" type="password" />

    <label>@T("Підтвердження нового пароля", "Confirm new password")</label>
    <input asp-for="ConfirmPassword" type="password" />

    <div class="form-actions">
        <button class="btn-primary" type="submit">@T("Зберегти", "Save")</button>
        <a class="btn-outline" href="/Account">@T("Назад", "Back")</a>
    </div>
</form>