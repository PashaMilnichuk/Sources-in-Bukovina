@model CarpathianCrown.Web.Models.OccupancyCalendarDto
@using CarpathianCrown.Web.Models

@{
    var lang = Context.GetLang();
    string T(string ua, string en) => lang == "en" ? en : ua;
    string RoomTitle(OccupancyCalendarRoomDto r) => lang == "en" ? r.NameEn : r.NameUa;
}

<h1>@T("Календар зайнятості номерів", "Room occupancy calendar")</h1>

<form method="get" style="margin-bottom:20px; display:flex; gap:12px; align-items:end; flex-wrap:wrap;">
    <div>
        <label>@T("Початок", "Start date")</label>
        <input type="date" name="start" value="@Model.Start.ToString("yyyy-MM-dd")" />
    </div>

    <div>
        <label>@T("Кількість днів", "Days")</label>
        <select name="days">
            <option value="7" selected="@(Model.Days == 7)">7</option>
            <option value="14" selected="@(Model.Days == 14)">14</option>
            <option value="21" selected="@(Model.Days == 21)">21</option>
            <option value="31" selected="@(Model.Days == 31)">31</option>
        </select>
    </div>

    <button class="btn-primary">@T("Показати", "Show")</button>
</form>

<div class="occupancy-legend">
    <div><span class="legend-box free"></span> @T("Вільно", "Free")</div>
    <div><span class="legend-box busy"></span> @T("Зайнято", "Busy")</div>
</div>

<div class="occupancy-table-wrap">
    <table class="occupancy-table">
        <thead>
            <tr>
                <th class="sticky-col">@T("Номер", "Room")</th>
                @foreach (var d in Model.Dates)
                {
                <th>
                    <div>@d.ToString("dd.MM")</div>
                    <div style="font-size:11px; color:#777;">@d.ToString("ddd")</div>
                </th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model.Rooms)
        {
            <tr>
                <td class="sticky-col room-name-cell">
                    <div style="font-weight:700;">@RoomTitle(room)</div>
                    <div style="font-size:12px; color:#777;">@room.Status</div>
                </td>

                @foreach (var day in room.Days)
                {
                <td>
                    <div class="day-box @(day.IsBusy ? "busy" : "free")"></div>
                </td>
                }
            </tr>
        }
        </tbody>
    </table>
</div>