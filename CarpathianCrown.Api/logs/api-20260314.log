LEFT JOIN (
    SELECT b0."Id", b0."BookingId", b0."LineTotal", b0."Quantity", b0."ServiceItemId", b0."UnitPrice", s."Id" AS "Id0", s."Category", s."DescriptionEn", s."DescriptionUa", s."ImageUrl", s."IsActive", s."NameEn", s."NameUa", s."Price"
