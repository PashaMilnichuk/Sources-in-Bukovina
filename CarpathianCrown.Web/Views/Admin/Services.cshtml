@model List<CarpathianCrown.Web.Models.ServiceItemDto>

    <h1>Admin — Services</h1>

    <p><a class="btn-primary" href="/Admin/CreateService">Create service</a></p>

    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Category</th>
                <th>Price</th>
                <th>Active</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
    {
            <tr>
                <td>@s.Id</td>
                <td>@s.NameEn</td>
                <td>@s.Category</td>
                <td>@s.Price</td>
                <td>@s.IsActive</td>
                <td style="display:flex; gap:8px;">
                    <a class="btn-outline" href="/Admin/EditService?id=@s.Id">Edit</a>
                    <form method="post" action="/Admin/DeleteService" onsubmit="return confirm('Delete service?')">
                        <input type="hidden" name="id" value="@s.Id" />
                        <button class="btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
    }
        </tbody>
    </table>
