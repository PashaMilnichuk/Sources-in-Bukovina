@model CarpathianCrown.Web.Models.AdminServiceFormVm

@{
    var isEdit = Model.Id > 0;
}

<h1>@(isEdit ? "Edit service" : "Create service")</h1>

<form method="post" action="@(isEdit ? "/Admin/EditService" : "/Admin/CreateService")">
    <input type="hidden" asp-for="Id" />

    <label>Category</label>
    <input asp-for="Category" />

    <label>Name UA</label>
    <input asp-for="NameUa" />

    <label>Name EN</label>
    <input asp-for="NameEn" />

    <label>Description UA</label>
    <textarea asp-for="DescriptionUa"></textarea>

    <label>Description EN</label>
    <textarea asp-for="DescriptionEn"></textarea>

    <label>Price</label>
    <input asp-for="Price" type="number" step="0.01" />

    <label>Image URL</label>
    <input asp-for="ImageUrl" />

    <label style="display:flex; gap:8px; align-items:center; margin-top:10px;">
        <input asp-for="IsActive" type="checkbox" style="width:auto;" />
        Active
    </label>

    <div style="margin-top:16px; display:flex; gap:10px;">
        <button class="btn-primary" type="submit">Save</button>
        <a class="btn-outline" href="/Admin/Services">Back</a>
    </div>
</form>