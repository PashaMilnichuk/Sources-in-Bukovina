SELECT b."RoomId" AS "roomId", r."NameUa" AS "nameUa", r."NameEn" AS "nameEn", count(*)::int AS bookings, COALESCE(sum(b."GrandTotal"), 0.0) AS revenue
FROM "Bookings" AS b
INNER JOIN "Rooms" AS r ON b."RoomId" = r."Id"
WHERE b."Status" <> 'Cancelled'
GROUP BY b."RoomId", r."NameUa", r."NameEn"
