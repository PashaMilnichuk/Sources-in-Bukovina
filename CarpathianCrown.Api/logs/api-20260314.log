SELECT b."Id", b."CheckIn", b."CheckOut", b."CreatedAt", b."GrandTotal", b."RoomId", b."RoomTotal", b."ServicesTotal", b."Status", b."UserId", r."Id", r."Capacity", r."CoverImageUrl", r."DescriptionEn", r."DescriptionUa", r."Image2", r."Image3", r."Image4", r."NameEn", r."NameUa", r."PricePerNight", r."Status", r0."Id", s0."Id", s0."BookingId", s0."LineTotal", s0."Quantity", s0."ServiceItemId", s0."UnitPrice", s0."Id0", s0."Category", s0."DescriptionEn", s0."DescriptionUa", s0."ImageUrl", s0."IsActive", s0."NameEn", s0."NameUa", s0."Price", r0."BookingId", r0."Comment", r0."CreatedAt", r0."Rating", r0."UserId"
FROM "Bookings" AS b
INNER JOIN "Rooms" AS r ON b."RoomId" = r."Id"
LEFT JOIN "Reviews" AS r0 ON b."Id" = r0."BookingId"
LEFT JOIN (
    SELECT b0."Id", b0."BookingId", b0."LineTotal", b0."Quantity", b0."ServiceItemId", b0."UnitPrice", s."Id" AS "Id0", s."Category", s."DescriptionEn", s."DescriptionUa", s."ImageUrl", s."IsActive", s."NameEn", s."NameUa", s."Price"
    FROM "BookingServices" AS b0
    INNER JOIN "ServiceItems" AS s ON b0."ServiceItemId" = s."Id"
) AS s0 ON b."Id" = s0."BookingId"
